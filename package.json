{
  "name": "todo-belt",
  "version": "1.0.0",
  "description": "TODO BELT - Productividad amable, enfocada y motivadora.",
  "author": "TODO BELT Team",
  "homepage": "https://todobelt.app",
  "scripts": {
    "ng": "ng",
    "start": "ionic serve",
    "build": "ng build",
    "build:stats": "ng build --configuration production --stats-json",
    "analyze": "ng build --configuration production --stats-json && npx -y source-map-explorer www/*.js",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "sync": "ionic build && cap sync",
    "cordova:android": "ionic cordova build android",
    "cordova:android:run": "ionic cordova run android",
    "cordova:android:emulate": "ionic cordova emulate android",
    "cordova:ios": "ionic cordova build ios",
    "cordova:ios:run": "ionic cordova run ios",
    "cordova:ios:emulate": "ionic cordova emulate ios"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/router": "^19.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@ionic/angular": "^8.4.0",
    "firebase": "^12.13.0",
    "ionicons": "^7.4.0",
    "rxjs": "~7.8.0",
    "swiper": "^11.1.14",
    "tslib": "^2.6.2",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.0.0",
    "@angular/cli": "^19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "@angular/language-service": "^19.0.0",
    "@capacitor/cli": "^6.1.0",
    "@ionic/angular-toolkit": "^11.0.1",
    "@types/node": "^20.10.0",
    "typescript": "~5.6.0"
  },
  "cordova": {
    "plugins": {
      "cordova-plugin-whitelist": {},
      "cordova-plugin-statusbar": {},
      "cordova-plugin-device": {},
      "cordova-plugin-splashscreen": {},
      "cordova-plugin-ionic-webview": {},
      "cordova-plugin-ionic-keyboard": {}
    },
    "platforms": []
  }
}
